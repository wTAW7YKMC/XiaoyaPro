<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部导航栏 -->
        <LinearLayout
            android:id="@+id/top_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="16dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">

            <!-- 返回箭头 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&lt;"
                android:textColor="@color/color_text_link"
                android:textSize="24sp"
                android:paddingEnd="4dp" />

            <!-- 建筑图标 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏛️"
                android:textSize="20sp" />

            <!-- 选择学校文字 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择学校"
                android:textColor="@color/color_text_link"
                android:textSize="14sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- 主内容区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="8dp">

            <!-- Logo区域 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp">

                <!-- Logo图标（蓝色建筑） -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_logo_blue" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="🏛️"
                        android:textSize="36sp" />
                </FrameLayout>

                <!-- 理工智课文字 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="理工智课"
                    android:textColor="#1E40AF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- 副标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="欢迎回来"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 当前学校标签 -->
            <LinearLayout
                android:id="@+id/layout_current_school"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_school_tag"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏫"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_current_school"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="武汉理工大学"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- 手机号/账号输入框 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <!-- 用户图标 -->
                <TextView
                    android:id="@+id/icon_user"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="👤"
                    android:textSize="16sp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp" />

                <!-- 输入框 -->
                <EditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_toEndOf="@id/icon_user"
                    android:layout_marginStart="12dp"
                    android:hint="请输入手机号/账号"
                    android:inputType="text"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="12dp"
                    android:paddingEnd="16dp"
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />
            </RelativeLayout>

            <!-- 密码输入框 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <!-- 锁图标 -->
                <TextView
                    android:id="@+id/icon_lock"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="🔒"
                    android:textSize="16sp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp" />

                <!-- 输入框 -->
                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_toStartOf="@id/btn_toggle_password"
                    android:layout_toEndOf="@id/icon_lock"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:hint="请输入密码"
                    android:inputType="textPassword"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="12dp"
                    android:paddingEnd="16dp"
                    android:textSize="15sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />

                <!-- 显示/隐藏密码按钮 -->
                <TextView
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:text="👁️"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </RelativeLayout>

            <!-- 登录按钮 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="登录"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:layout_marginBottom="12dp"
                android:elevation="4dp" />

            <!-- 忘记密码链接 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tv_forgot_password"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="忘记密码 >"
                    android:textColor="@color/color_text_link"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <!-- 分隔线 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#D1D5DB" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="其他登录方式"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginHorizontal="12dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#D1D5DB" />
            </LinearLayout>

            <!-- 统一身份认证按钮 -->
            <LinearLayout
                android:id="@+id/btn_unified_auth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_unified_auth_btn"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="统一身份认证"
                    android:textColor="@color/color_text_link"
                    android:textSize="14sp"
                    android:textStyle="normal"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- 底部协议 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="center_horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="32dp">

                <!-- 协议勾选框（已勾选状态） -->
                <CheckBox
                    android:id="@+id/checkbox_agreement"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:checked="true"
                    android:buttonTint="@color/color_primary"
                    android:layout_marginEnd="8dp" />

                <!-- 协议文字 -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="登录即表示同意平台《用户服务协议》和《隐私政策》"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.2" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</ScrollView>
