<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- 右上角个人空间按钮 -->
            <LinearLayout
                android:id="@+id/btn_personal_space"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="end"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个人空间"
                    android:textColor="@color/color_text_link"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" >"
                    android:textColor="@color/color_text_link"
                    android:textSize="14sp"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

            <!-- 欢迎区域 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <!-- 书本/文件堆叠图标 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚"
                    android:textSize="36sp" />

                <!-- 欢迎文字 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HI 很高兴见到你！"
                    android:textColor="@color/color_text_link"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 主内容区（带负margin实现卡片重叠效果） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:marginTop="-16dp">

            <!-- 用户信息卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 用户基本信息行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <!-- 头像容器 -->
                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="12dp">

                            <!-- 圆形头像背景 -->
                            <View
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/bg_avatar_circle" />

                            <!-- 头像Emoji（卡通男生戴学士帽） -->
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="👨‍🎓"
                                android:textSize="28sp" />
                        </FrameLayout>

                        <!-- 用户名和箭头 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tv_user_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="喻贝贝"
                                    android:textColor="@color/color_text_primary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=" >"
                                    android:textColor="@color/color_text_secondary"
                                    android:textSize="18sp"
                                    android:layout_marginStart="4dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 学校名称 -->
                    <TextView
                        android:id="@+id/tv_user_school"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="武汉理工大学"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="20dp" />

                    <!-- 分割线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F3F4F6"
                        android:layout_marginBottom="16dp" />

                    <!-- 统计数据区域 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- 学习课程 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="学习课程"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_course_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="61"
                                android:textColor="@color/color_text_primary"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 竖线分隔符 -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#E5E7EB" />

                        <!-- 待完成任务 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="待完成任务"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="12sp"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_task_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2"
                                android:textColor="@color/color_text_primary"
                                android:textSize="24sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 功能入口网格（2列） -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true">

                <!-- 我的课程 -->
                <include
                    android:id="@+id/entry_courses"
                    layout="@layout/item_function_entry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />

                <!-- 我的文档 -->
                <include
                    android:id="@+id/entry_documents"
                    layout="@layout/item_function_entry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />

                <!-- 任务提醒 -->
                <include
                    android:id="@+id/entry_tasks"
                    layout="@layout/item_function_entry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1" />

                <!-- 发现（带AI角标） -->
                <FrameLayout
                    android:id="@+id/entry_discover"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1">

                    <include
                        layout="@layout/item_function_entry" />

                    <!-- AI机器人头像角标 -->
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="12dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_ai_badge"
                        android:gravity="center"
                        android:text="🤖"
                        android:textSize="14sp" />
                </FrameLayout>
            </GridLayout>
        </LinearLayout>

        <!-- 底部留白，防止内容被TabBar遮挡 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />
    </LinearLayout>

</ScrollView>
