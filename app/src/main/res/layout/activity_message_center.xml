<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_page"
    android:orientation="vertical">

    <!-- 顶部标题栏 -->
    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="2dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <!-- 标题 -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:text="消息中心"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 更多按钮（三个点） -->
        <TextView
            android:id="@+id/btn_more"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="⋯"
            android:textColor="@color/color_text_secondary"
            android:textSize="24sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </RelativeLayout>

    <!-- 消息分类列表 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 待办事项 -->
            <include
                android:id="@+id/item_todo"
                layout="@layout/item_message_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <!-- 课程消息（带未读红点） -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <include
                    android:id="@+id/item_course_msg"
                    layout="@layout/item_message_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <!-- 未读红点 -->
                <View
                    android:id="@+id/red_dot_course"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="40dp"
                    android:background="@drawable/bg_red_dot" />
            </FrameLayout>

            <!-- 个人消息 -->
            <include
                android:id="@+id/item_personal_msg"
                layout="@layout/item_message_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <!-- 系统消息 -->
            <include
                android:id="@+id/item_system_msg"
                layout="@layout/item_message_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <!-- 群聊 -->
            <include
                android:id="@+id/item_group_chat"
                layout="@layout/item_message_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <!-- 私信 -->
            <include
                android:id="@+id/item_private_msg"
                layout="@layout/item_message_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <!-- 通讯录 -->
            <include
                android:id="@+id/item_contacts"
                layout="@layout/item_message_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
