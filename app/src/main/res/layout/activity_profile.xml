<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部装饰背景 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="128dp"
            android:background="@drawable/bg_top_decoration_cyan" />

        <!-- 主内容区（带负margin实现卡片重叠效果） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:marginTop="-80dp">

            <!-- 用户信息卡片 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <!-- 头像容器（带标签角标） -->
                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="12dp">

                        <!-- 圆形头像背景 -->
                        <View
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_avatar_circle" />

                        <!-- 头像Emoji（卡通男生戴学士帽） -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="👨‍🎓"
                            android:textSize="30sp" />

                        <!-- 普通用户标签角标 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|end"
                            android:text="普通用户"
                            android:textColor="#F59E0B"
                            android:textSize="10sp"
                            android:textStyle="normal"
                            android:background="@drawable/bg_user_tag"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:layout_marginEnd="-4dp"
                            android:layout_marginBottom="-4dp" />
                    </FrameLayout>

                    <!-- 用户信息 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- 用户名 -->
                        <TextView
                            android:id="@+id/tv_user_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="喻贝贝"
                            android:textColor="@color/color_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- 学校名称 -->
                        <TextView
                            android:id="@+id/tv_user_school"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="武汉理工大学"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- 右箭头 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 功能列表 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- 个人数据看板 -->
                <include
                    android:id="@+id/menu_dashboard"
                    layout="@layout/item_menu_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp" />

                <!-- 我的报告 -->
                <include
                    android:id="@+id/menu_report"
                    layout="@layout/item_menu_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp" />

                <!-- 反馈&建议 -->
                <include
                    android:id="@+id/menu_feedback"
                    layout="@layout/item_menu_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp" />

                <!-- 投诉举报 -->
                <include
                    android:id="@+id/menu_complaint"
                    layout="@layout/item_menu_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp" />

                <!-- 关于小雅 -->
                <include
                    android:id="@+id/menu_about"
                    layout="@layout/item_menu_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- 退出登录按钮 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_logout"
                style="@style/ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="32dp"
                android:text="退出登录"
                android:elevation="4dp" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>
