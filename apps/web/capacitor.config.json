{
  "appId": "com.xiaoya.app",
  "appName": "小雅智能助手",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#10B981",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "backgroundColor": "#10B981",
      "style": "LIGHT",
      "overlaysWebView": true
    },
    "Keyboard": {
      "resize": "body"
    }
  }
}
