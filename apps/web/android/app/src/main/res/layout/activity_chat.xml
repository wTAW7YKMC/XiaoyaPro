<?xml version="1.0" encoding="utf-8"?>
<!--
  AI对话界面布局 - 参考小雅智能助手系统帮助页面样式
  设计特点：
  1. 青绿色主题色 (#10B981)
  2. 圆角卡片设计
  3. 消息气泡样式区分用户和AI
  4. 底部输入框和发送按钮
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- 顶部标题栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@android:color/white"
        android:elevation="4dp">

        <!-- 返回按钮 -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:src="@android:drawable/ic_menu_revert" />

        <!-- 标题文字 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="小雅AI助手"
            android:textColor="#1F2937"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 清空对话按钮 -->
        <TextView
            android:id="@+id/btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:text="清空"
            android:textColor="#10B981"
            android:textSize="14sp" />

    </RelativeLayout>

    <!-- 消息列表区域 -->
    <ScrollView
        android:id="@+id/scroll_view_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/layout_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AI欢迎消息卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@android:color/white"
                android:orientation="vertical"
                android:padding="16dp"
                android:radius="16dp">

                <!-- AI头像和消息区域 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:orientation="horizontal">

                    <!-- AI头像 -->
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_dialog_info"
                        android:contentDescription="AI头像"
                        android:background="@drawable/ai_avatar_bg"
                        android:padding="8dp" />

                    <!-- 欢迎消息内容 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="您好，请问有什么可以帮您？"
                            android:textColor="#1F2937"
                            android:textSize="15sp"
                            android:lineSpacingMultiplier="1.3" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="若您需要人工协助，请选择接入人工客服的方式"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                        <!-- 启动网页会话按钮 -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/button_outline_bg"
                            android:paddingLeft="20dp"
            android:paddingRight="20dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:text="🤖 启动AI会话"
                            android:textColor="#10B981"
                            android:textSize="14sp" />

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- 动态添加的消息将显示在这里 -->

        </LinearLayout>

    </ScrollView>

    <!-- 快捷问题标签栏 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingRight="16dp">

            <!-- 常见问题标签 -->
            <TextView
                android:id="@+id/tag_common"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/tag_selected_bg"
                android:gravity="center"
                android:paddingLeft="16dp"
            android:paddingRight="16dp"
                android:text="常见问题"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tag_study"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/tag_unselected_bg"
                android:gravity="center"
                android:paddingLeft="16dp"
            android:paddingRight="16dp"
                android:text="学习辅导"
                android:textColor="#6B7280"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tag_homework"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/tag_unselected_bg"
                android:gravity="center"
                android:paddingLeft="16dp"
            android:paddingRight="16dp"
                android:text="作业帮助"
                android:textColor="#6B7280"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tag_course"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/tag_unselected_bg"
                android:gravity="center"
                android:paddingLeft="16dp"
            android:paddingRight="16dp"
                android:text="课程咨询"
                android:textColor="#6B7280"
                android:textSize="13sp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- 底部输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- 输入框 -->
        <EditText
            android:id="@+id/edit_message"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/input_bg"
            android:hint="请输入..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:textColor="#1F2937"
            android:textColorHint="#9CA3AF"
            android:textSize="14sp" />

        <!-- 发送按钮 -->
        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/send_button_bg"
            android:contentDescription="发送"
            android:src="@android:drawable/ic_menu_send"
            android:tint="@android:color/white" />

    </LinearLayout>

</LinearLayout>
