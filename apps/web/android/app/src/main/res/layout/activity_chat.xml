<?xml version="1.0" encoding="utf-8"?>
<!--
  系统帮助 / AI对话界面布局
  参考系统帮助页面样式：
  1. 顶部白色标题栏：返回 + 系统帮助
  2. 灰色背景聊天区
  3. AI欢迎卡片：企鹅头像 + 问候语 + 人工客服引导 + 启动网页会话按钮
  4. 常见问题卡片：标签栏 + 问题列表 + 查看更多
  5. 底部输入区：启动网页会话快捷入口 + 输入框
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:orientation="vertical">

    <!-- 顶部标题栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@android:color/white">

        <!-- 返回按钮 -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:paddingStart="16dp"
            android:src="@drawable/ic_arrow_back" />

        <!-- 标题文字 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="系统帮助"
            android:textColor="#1F2937"
            android:textSize="18sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- 消息列表区域 -->
    <ScrollView
        android:id="@+id/scroll_view_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layout_messages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 当前时间 -->
            <TextView
                android:id="@+id/tv_chat_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:text="10:51"
                android:textColor="#9CA3AF"
                android:textSize="13sp" />

            <!-- AI欢迎消息卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- AI头像和消息区域 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:orientation="horizontal">

                    <!-- AI头像 -->
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/floating_ai_button_bg"
                        android:contentDescription="AI头像"
                        android:padding="8dp"
                        android:src="@drawable/ic_penguin" />

                    <!-- 欢迎消息内容 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:lineSpacingMultiplier="1.3"
                            android:text="您好，请问有什么可以帮您？"
                            android:textColor="#1F2937"
                            android:textSize="15sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="0.5dp"
                            android:layout_marginVertical="12dp"
                            android:background="#E5E7EB" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:lineSpacingMultiplier="1.3"
                            android:text="若您需要人工协助，请选择转接人工客服的方式"
                            android:textColor="#6B7280"
                            android:textSize="14sp" />

                        <!-- 启动网页会话按钮 -->
                        <LinearLayout
                            android:id="@+id/btn_web_session_top"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/button_outline_blue_bg"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_customer_service" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="启动网页会话"
                                android:textColor="#3B82F6"
                                android:textSize="14sp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- 常见问题卡片 -->
            <LinearLayout
                android:id="@+id/card_faq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:paddingVertical="12dp">

                <!-- 标签栏 -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:id="@+id/tag_common"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/tag_help_selected_bg"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="常见问题"
                            android:textColor="#3B82F6"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tag_teaching_activity"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/tag_help_unselected_bg"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="教学活动"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tag_course_manage"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/tag_help_unselected_bg"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="课程管理"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tag_teaching"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:background="@drawable/tag_help_unselected_bg"
                            android:gravity="center"
                            android:paddingHorizontal="16dp"
                            android:text="教学"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- 问题列表 -->
                <LinearLayout
                    android:id="@+id/list_faq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp">

                    <TextView
                        android:id="@+id/faq_item_1"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="如何开启签到"
                        android:textColor="#374151"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#E5E7EB" />

                    <TextView
                        android:id="@+id/faq_item_2"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="如何更改签到状态"
                        android:textColor="#374151"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#E5E7EB" />

                    <TextView
                        android:id="@+id/faq_item_3"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="如何延长任务截止时间？"
                        android:textColor="#374151"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#E5E7EB" />

                    <TextView
                        android:id="@+id/faq_item_4"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="如何设置总评成绩计分项"
                        android:textColor="#374151"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#E5E7EB" />

                    <TextView
                        android:id="@+id/faq_item_5"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="如何开启随机选人/选组"
                        android:textColor="#374151"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#E5E7EB" />

                    <TextView
                        android:id="@+id/faq_item_6"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:gravity="center_vertical"
                        android:text="如何发布任务？"
                        android:textColor="#374151"
                        android:textSize="15sp" />

                </LinearLayout>

                <!-- 查看更多 -->
                <TextView
                    android:id="@+id/btn_view_more"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center"
                    android:text="查看更多"
                    android:textColor="#9CA3AF"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 底部输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- 启动网页会话快捷入口 -->
        <LinearLayout
            android:id="@+id/btn_web_session_bottom"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/button_outline_blue_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_customer_service" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="启动网页会话"
                android:textColor="#3B82F6"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 输入框 -->
        <EditText
            android:id="@+id/edit_message"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/input_bg"
            android:hint="请输入..."
            android:inputType="text"
            android:maxLines="1"
            android:paddingHorizontal="16dp"
            android:textColor="#1F2937"
            android:textColorHint="#9CA3AF"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
