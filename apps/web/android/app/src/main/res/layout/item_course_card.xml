<?xml version="1.0" encoding="utf-8"?>
<!--
    课程卡片项布局 - 一比一复刻截图中的卡片样式
    
    包含：
    - 左侧：封面图片 + 学期标签 + 类型标签
    - 右侧：课程名称、学院、教师、访问量、进度条
-->
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- 左侧：封面图片区域 -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp">

            <!-- 封面图 -->
            <ImageView
                android:id="@+id/iv_cover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/cover_placeholder_bg"
                android:contentDescription="课程封面" />

            <!-- 学期标签（左上角） -->
            <TextView
                android:id="@+id/tv_semester_tag"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:layout_gravity="top|start"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:gravity="center"
                android:text="2026年春"
                android:textSize="9sp"
                android:textColor="@android:color/white"
                android:background="#CC000000" />

            <!-- 类型标签（左下角） -->
            <TextView
                android:id="@+id/tv_type_tag"
                android:layout_width="wrap_content"
                android:layout_height="18dp"
                android:layout_gravity="bottom|start"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:gravity="center"
                android:text="校内|教务"
                android:textSize="9sp"
                android:textColor="@android:color/white"
                android:background="#CC000000" />
        </FrameLayout>

        <!-- 右侧：课程信息区域 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- 课程标题 -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="国际学术交流基础"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- 学院信息 -->
            <TextView
                android:id="@+id/tv_school"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="学院: 外国语学院"
                android:textSize="12sp"
                android:textColor="#666666" />

            <!-- 教师姓名 -->
            <TextView
                android:id="@+id/tv_teacher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="申震"
                android:textSize="12sp"
                android:textColor="#666666" />

            <!-- 访问量信息行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 访问量图标和文字 -->
                <TextView
                    android:id="@+id/tv_visit_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👁️访问量:外国语..."
                    android:textSize="11sp"
                    android:textColor="#888888" />

                <!-- 访问人数（右对齐） -->
                <TextView
                    android:id="@+id/tv_visit_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="👥234人"
                    android:textSize="11sp"
                    android:textColor="#888888" />
            </LinearLayout>

            <!-- 学习进度条区域（仅"我学的课"显示） -->
            <LinearLayout
                android:id="@+id/layout_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="visible">

                <!-- 进度条 -->
                <ProgressBar
                    android:id="@+id/progress_bar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="65"
                    android:progressDrawable="@drawable/progress_bar_green" />

                <!-- 进度百分比文本 -->
                <TextView
                    android:id="@+id/tv_progress_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="65%"
                    android:textSize="11sp"
                    android:textColor="@color/primary_green"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
